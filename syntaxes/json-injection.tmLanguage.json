{
  "scopeName": "source.embedded.json-injection",
  "injectionSelector": "L:source.json",
  "patterns": [
    {
      "name": "meta.embedded.inline.ts",
      "begin": "\"(::|ts:)",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.ts comment" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.ts comment" }
      },
      "contentName": "source.ts",
      "patterns": [
        { "include": "source.ts" }
      ]
    }
  ]
}