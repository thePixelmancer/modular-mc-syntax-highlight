{
  "name": "modular-mc-syntax",
  "displayName": "Modular MC",
  "description": "Features for the ModularMC regolith filter",
  "version": "0.2.0",
  "icon": "icon.png",
  "publisher": "Pixelmancer",
  "author": {
    "name": "Pixelmancer"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thePixelmancer/modular-mc-syntax-highlight.git"
  },
  "bugs": {
    "url": "https://github.com/thePixelmancer/modular-mc-syntax-highlight/issues"
  },
  "homepage": "https://github.com/thePixelmancer/modular-mc-syntax-highlight#readme",
  "keywords": [
    "modularmc",
    "minecraft",
    "regolith",
    "typescript",
    "syntax-highlighting",
    "language-injection"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc"
  },
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:plaintext"
  ],
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/map.code-snippets"
      }
    ],
    "grammars": [
      {
        "scopeName": "source.embedded.plain-injection",
        "path": "./syntaxes/plain-injection.tmLanguage.json",
        "language": "plaintext",
        "injectTo": [
          "text.plain",
          "text.plain.textmate"
        ],
        "embeddedLanguages": {
          "source.ts": "typescript"
        }
      },
      {
        "scopeName": "source.embedded.json-injection",
        "path": "./syntaxes/json-injection.tmLanguage.json",
        "injectTo": [
          "source.json"
        ],
        "embeddedLanguages": {
          "source.ts": "typescript"
        }
      },
      {
        "scopeName": "source.embedded.lang-injection",
        "path": "./syntaxes/lang-injection.tmLanguage.json",
        "injectTo": [
          "source.lang"
        ],
        "embeddedLanguages": {
          "source.ts": "typescript"
        }
      }
    ]
  }
}
